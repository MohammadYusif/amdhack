ALLOWED_ORIGINS=http://localhost:3000,https://mihan-demo.yourcompany.com

# Required for the live Wathq proof (/wathq-live-proof, the 🔴 button in
# the demo). Without these, everything falls back to simulation — the
# demo still works, but the live-proof moment shows "live": false.
WATHQ_CONSUMER_KEY=<your developer.wathq.sa consumer key>
WATHQ_CONSUMER_SECRET=<your developer.wathq.sa consumer secret>
WATHQ_BASE_URL=https://api.wathq.sa/sandbox/commercial-registration

# Only needed to regenerate backend/explanations.json (generate_cache.py).
# Not read by the live API — set as a shell env var when running that script.
ANTHROPIC_API_KEY=sk-ant-...
